# Django core settings
DJANGO_SECRET_KEY=change-this-local-dev-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL settings (intended database)
# For host-run backend use POSTGRES_HOST=localhost.
# For Docker Compose backend use POSTGRES_HOST=postgres (service name).
POSTGRES_DB=zentry_db
POSTGRES_USER=zentry_user
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT lifetime settings
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Refresh-token cookie settings
# Use secure=false for plain HTTP local development.
# In production behind HTTPS, set AUTH_COOKIE_SECURE=true.
AUTH_COOKIE_REFRESH_NAME=refresh_token
AUTH_COOKIE_REFRESH_PATH=/api/v1/auth/
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAMESITE=Lax
